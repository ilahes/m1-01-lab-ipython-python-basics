   "source": [
    "#task 4\n",
    "# 1. Create the list of 12 dictionaries (including 2 invalid ones)\n",
    "raw_events = [\n",
    "    {\"user_id\": 101, \"event_type\": \"click\", \"duration_seconds\": 5},\n",
    "    {\"user_id\": 102, \"event_type\": \"scroll\", \"duration_seconds\": 120},\n",
    "    {\"user_id\": 101, \"event_type\": \"click\", \"duration_seconds\": -10}, # Invalid: Negative\n",
    "    {\"user_id\": 103, \"event_type\": \"view\", \"duration_seconds\": 300},\n",
    "    {\"user_id\": 104, \"event_type\": \"scroll\", \"duration_seconds\": \"invalid\"}, # Invalid: String\n",
    "    {\"user_id\": 102, \"event_type\": \"view\", \"duration_seconds\": 45},\n",
    "    {\"user_id\": 105, \"event_type\": \"click\", \"duration_seconds\": 15},\n",
    "    {\"user_id\": 106, \"event_type\": \"scroll\", \"duration_seconds\": 200},\n",
    "    {\"user_id\": 101, \"event_type\": \"view\", \"duration_seconds\": 60},\n",
    "    {\"user_id\": 103, \"event_type\": \"click\", \"duration_seconds\": 10},\n",
    "    {\"user_id\": 107, \"event_type\": \"scroll\", \"duration_seconds\": 90},\n",
    "    {\"user_id\": 108, \"event_type\": \"view\", \"duration_seconds\": 180}\n",
    "]\n",
    "\n",
    "cleaned_events = []\n",
    "\n",
    "# 2. Loop to clean data and transform\n",
    "for event in raw_events:\n",
    "    duration = event.get(\"duration_seconds\")\n",
    "    \n",
    "    # Validation: Check if it's a number and non-negative\n",
    "    if isinstance(duration, (int, float)) and duration >= 0:\n",
    "        # Create a copy to avoid mutating the original raw_events\n",
    "        clean_entry = event.copy()\n",
    "        clean_entry[\"duration_minutes\"] = duration / 60\n",
    "        cleaned_events.append(clean_entry)\n",
    "\n",
    "# 3. Verification\n",
    "print(f\"Total raw records: {len(raw_events)}\")\n",
    "print(f\"Total cleaned records: {len(cleaned_events)}\") # Should be 10\n",
    "print(f\"All records have 'duration_minutes': {all('duration_minutes' in e for e in cleaned_events)}\")\n",
    "\n",
    "# 4. Inspect two records (IPython style)\n",
    "cleaned_events[:2]"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "f3d102bd-e3fd-42a3-a0a3-02ed08f109dd",
   "metadata": {},
   "source": [
    "### task 4\n",
    "Validation: Removed invalid records (negative or non-numeric durations) using isinstance() and condition checks.\n",
    "Transformation: Added duration_minutes by converting seconds to minutes for each valid record.\n",
    "Immutability: Used event.copy() so the original raw_events list stays unchanged.\n",
    "After cleaning, cleaned_events contains 10 valid records, each with duration_minutes."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 2,
   "id": "51dc4151-b9f7-446e-bb5b-20804cbb71fc",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "metric,key,value\n",
      "count,click,3\n",
      "count,scroll,3\n",
      "count,view,4\n",
      "average_minutes,click,0.17\n",
      "average_minutes,scroll,2.28\n",
      "average_minutes,view,2.44\n",
      "unique_users,,7\n"
     ]
    }
   ],
   "source": [
    "# Task 5: Summaries\n",
    "\n",
    "# Event counts by event_type\n",
    "event_counts = {}\n",
    "for e in cleaned_events:\n",
    "    event_counts[e[\"event_type\"]] = event_counts.get(e[\"event_type\"], 0) + 1\n",
    "\n",
    "# Average duration_minutes by event_type\n",
    "event_totals = {}\n",
    "for e in cleaned_events:\n",
    "    event_totals[e[\"event_type\"]] = event_totals.get(e[\"event_type\"], 0) + e[\"duration_minutes\"]\n",
    "\n",
    "avg_duration = {etype: event_totals[etype] / event_counts[etype] for etype in event_counts}\n",
    "\n",
    "# Number of unique users\n",
    "unique_users = len({e[\"user_id\"] for e in cleaned_events})\n",
    "\n",
    "# Validation\n",
    "assert sum(event_counts.values()) == len(cleaned_events), \"Event counts mismatch!\"\n",
    "\n",
    "# Build CSV-formatted string\n",
    "csv_lines = [\"metric,key,value\"]\n",
    "for etype, count in event_counts.items():\n",
    "    csv_lines.append(f\"count,{etype},{count}\")\n",
    "for etype, avg in avg_duration.items():\n",
    "    csv_lines.append(f\"average_minutes,{etype},{avg:.2f}\")\n",
    "csv_lines.append(f\"unique_users,,{unique_users}\")\n",
    "\n",
    "csv_output = \"\\n\".join(csv_lines)\n",
    "\n",
    "print(csv_output)"
   ]
  },

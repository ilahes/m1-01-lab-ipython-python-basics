       "[{'user_id': 101,\n",
       "  'event_type': 'click',\n",
       "  'duration_seconds': 5,\n",
       "  'duration_minutes': 0.08333333333333333},\n",
       " {'user_id': 102,\n",
       "  'event_type': 'scroll',\n",
       "  'duration_seconds': 120,\n",
